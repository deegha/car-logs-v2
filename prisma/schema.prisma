generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─────────────────────────────────────────────
// Seller
// ─────────────────────────────────────────────

model Seller {
  id           Int          @id @default(autoincrement())
  firstName    String       @db.VarChar(100)
  lastName     String       @db.VarChar(100)
  email        String       @unique @db.VarChar(255)
  phone        String       @db.VarChar(30)
  passwordHash String       @db.VarChar(255)
  status       SellerStatus @default(ACTIVE)
  cars         Car[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([email])
}

// ─────────────────────────────────────────────
// Admin
// ─────────────────────────────────────────────

model Admin {
  id           Int      @id @default(autoincrement())
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255)
  createdAt    DateTime @default(now())
}

// ─────────────────────────────────────────────
// Car listing
// ─────────────────────────────────────────────

model Car {
  id           Int          @id @default(autoincrement())
  slug         String?      @unique @db.VarChar(300)
  title        String       @db.VarChar(200)
  make         String       @db.VarChar(100)
  model        String       @db.VarChar(100)
  year         Int
  price        Decimal      @db.Decimal(12, 2)
  mileage      Int
  color        String?      @db.VarChar(50)
  fuelType     FuelType     @default(PETROL)
  transmission Transmission @default(AUTOMATIC)
  bodyType     String?      @db.VarChar(50)
  engineSize   String?      @db.VarChar(20)
  description  String?      @db.Text
  province         String?      @db.VarChar(100)
  district         String?      @db.VarChar(100)
  town             String?      @db.VarChar(100)
  isNegotiable     Boolean      @default(false)
  emissionTestUrl  String?      @db.VarChar(500)
  status           CarStatus    @default(PENDING)
  featured     Boolean      @default(false)
  sellerId     Int
  seller       Seller       @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  images       CarImage[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([make, model])
  @@index([year])
  @@index([price])
  @@index([status])
  @@index([sellerId])
  @@fulltext([title, make, model])
}

model CarImage {
  id        Int      @id @default(autoincrement())
  url       String   @db.VarChar(500)
  alt       String?  @db.VarChar(200)
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  carId     Int
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum SellerStatus {
  ACTIVE
  SUSPENDED
}

enum CarStatus {
  PENDING
  AVAILABLE
  SOLD
  RESERVED
  REJECTED
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
  PLUGIN_HYBRID
}

enum Transmission {
  AUTOMATIC
  MANUAL
  CVT
}
