generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─────────────────────────────────────────────
// Seller
// ─────────────────────────────────────────────

model Seller {
  id           Int           @id @default(autoincrement())
  firstName    String        @db.VarChar(100)
  lastName     String        @db.VarChar(100)
  email        String        @unique @db.VarChar(255)
  passwordHash String        @db.VarChar(255)
  status       SellerStatus  @default(ACTIVE)
  cars         Car[]
  phones       SellerPhone[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([email])
}

model SellerPhone {
  id         Int      @id @default(autoincrement())
  number     String   @db.VarChar(20)
  isPrimary  Boolean  @default(false)
  isWhatsApp Boolean  @default(false)
  sellerId   Int
  seller     Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([sellerId])
}

// ─────────────────────────────────────────────
// Admin
// ─────────────────────────────────────────────

model Admin {
  id           Int      @id @default(autoincrement())
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255)
  createdAt    DateTime @default(now())
}

// ─────────────────────────────────────────────
// Car listing
// ─────────────────────────────────────────────

model Car {
  id           Int          @id @default(autoincrement())
  slug         String?      @unique @db.VarChar(300)
  title        String       @db.VarChar(200)
  make         String       @db.VarChar(100)
  model        String       @db.VarChar(100)
  year         Int
  price        Decimal      @db.Decimal(12, 2)
  mileage      Int
  color        String?      @db.VarChar(50)
  fuelType     FuelType     @default(PETROL)
  transmission Transmission @default(AUTOMATIC)
  bodyType     String?      @db.VarChar(50)
  engineSize   String?      @db.VarChar(20)
  description  String?      @db.Text
  province         String?      @db.VarChar(100)
  district         String?      @db.VarChar(100)
  town             String?      @db.VarChar(100)
  condition        CarCondition @default(USED)
  isNegotiable     Boolean      @default(false)
  emissionTestUrl  String?      @db.VarChar(500)
  status           CarStatus    @default(PENDING)
  featured     Boolean      @default(false)
  sellerId     Int
  seller       Seller       @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  images       CarImage[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Composite indexes leading with status — every public query filters status first
  @@index([status, createdAt])            // default listing + count (no extra filters)
  @@index([status, make, createdAt])      // make-filtered listing + related-cars query
  @@index([status, make, model])          // make+model filter
  @@index([status, featured, createdAt])  // homepage featured query
  @@index([status, bodyType])             // bodyType filter
  @@index([status, condition])            // condition filter
  // Keep single-column indexes for range-only queries
  @@index([year])
  @@index([price])
  @@index([sellerId])
  @@fulltext([title, make, model])
}

model CarImage {
  id        Int      @id @default(autoincrement())
  url       String   @db.VarChar(500)
  alt       String?  @db.VarChar(200)
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  carId     Int
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([carId, isPrimary]) // listing page: WHERE carId IN (...) AND isPrimary = true
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum SellerStatus {
  ACTIVE
  SUSPENDED
}

enum CarStatus {
  PENDING
  AVAILABLE
  SOLD
  RESERVED
  REJECTED
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
  PLUGIN_HYBRID
}

enum Transmission {
  AUTOMATIC
  MANUAL
  CVT
}

enum CarCondition {
  NEW
  USED
  RECONDITIONED
}
