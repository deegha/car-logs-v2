# Database — matches docker-compose.yml defaults
DATABASE_URL="mysql://cars_user:cars_password@localhost:3307/used_cars_db"

# Docker MySQL config
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=used_cars_db
MYSQL_USER=cars_user
MYSQL_PASSWORD=cars_password
MYSQL_PORT=3307

# Admin seed credentials (used by prisma/seed.ts only)
ADMIN_EMAIL=admin@prestigerides.com
ADMIN_PASSWORD=Admin1234!

# Auth
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Cloudinary — image uploads
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
